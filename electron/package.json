{
  "name": "pvlmtube-desktop",
  "version": "1.0.0",
  "description": "PVLM YouTube Downloader - Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.pvlm.ytdownloader",
    "productName": "PVLM YouTube Downloader",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "../static/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
